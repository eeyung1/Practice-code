PROGRAM Fprime

INPUT: Command-line argument (string representation of positive integer)
OUTPUT: Prime factorization as string (factors separated by *)

VARIABLES:
  n (integer) - the number to factorize
  divisor (integer) - current divisor being tested
  factors (array/slice of integers) - stores all prime factors
  result (string) - final output string

BEGIN

  // STEP 1: Validation
  IF len(arguments) != 2 THEN
    EXIT (print nothing)
  END IF
  
  TRY converting argument to integer → n
  CATCH conversion error:
    EXIT (print nothing)
  END TRY
  
  IF n <= 1 THEN
    EXIT (print nothing)
  END IF

  // STEP 2: Initialize
  factors = empty array/slice
  divisor = 2

  // STEP 3: Factorization
  WHILE n > 1 DO
    
    // Inner loop: divide by current divisor as many times as possible
    WHILE n % divisor == 0 DO
      APPEND divisor to factors
      n = n / divisor
    END WHILE
    
    // Move to next divisor
    divisor = divisor + 1
    
  END WHILE

  // STEP 4: Build output
  IF length(factors) == 0 THEN
    EXIT (shouldn't happen if n > 1)
  END IF
  
  result = JOIN factors with "*"
  PRINT result + newline

END PROGRAM


