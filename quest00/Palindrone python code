
Palindrome

Idef check_palindrome(s):
    if len(s) == 0:
        return True  

    for i in range(len(s) // 2):
        if s[i] != s[len(s)-1-i]:
            return False  

    return True  
    
print(check_palindrome("raecar"))
print(check_palindrome("hello"))
print(check_palindrome("A man a plan a canal Panama"))



